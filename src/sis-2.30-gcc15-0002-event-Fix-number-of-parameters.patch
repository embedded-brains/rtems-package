 {
   struct pollfd fds[1];
   int ret;
   unsigned char buffer[1536];
 
+  (void) arg;
+
   fds[0].fd = tun_fd;
   fds[0].events = POLLRDNORM;
   ret = poll (fds, 1, 0);
