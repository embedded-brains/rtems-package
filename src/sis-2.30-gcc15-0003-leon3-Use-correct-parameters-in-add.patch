From 64c48519bd46044f5a2fe62030563f4b98f58455 Mon Sep 17 00:00:00 2001
From: Christian Mauderer <christian.mauderer@embedded-brains.de>
Date: Thu, 23 Oct 2025 09:03:21 +0200
Subject: [PATCH 3/5] leon3: Use correct parameters in add

The function is passed to a pointer that expects 3 parameters. So add
them. This change is necessary to make the code compilable with C23.
---
 grlib.c | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/grlib.c b/grlib.c
index 0970303..d5e20d6 100644
--- a/grlib.c
+++ b/grlib.c
@@ -289,8 +289,11 @@ const struct grlib_ipcore l2c = {
 /* ------------------- LEON3 -----------------------*/
 
 static void
-leon3_add ()
+leon3_add (int irq, uint32 addr, uint32 mask)
 {
+  (void) irq;
+  (void) addr;
+  (void) mask;
   grlib_ahbmpp_add (GRLIB_PP_ID (VENDOR_GAISLER, GAISLER_LEON3, 0, 0));
   if (sis_verbose)
     printf (" LEON3 SPARC V8 processor                      \n");
-- 
